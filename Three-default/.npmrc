; ================================
; GitHub Packages registry config
; ================================

@KroxEngine:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

; ------------------------------------------------------------
; ⚠️ ВАЖНО:
; В файле НЕ хранится токен.
; Токен берётся из переменной окружения NODE_AUTH_TOKEN.
; ------------------------------------------------------------


; ============================================================
; 🔐 Как установить NODE_AUTH_TOKEN
; ============================================================

; 1️⃣ Windows (PowerShell)
; ------------------------------------------------------------
; setx NODE_AUTH_TOKEN "ghp_xxxxxxxxxxxxxxxxxxxxxxxxx"
;
; После этого ПЕРЕЗАПУСТИТЕ терминал.


; 2️⃣ macOS / Linux (временный, до закрытия терминала)
; ------------------------------------------------------------
; export NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxx


; 3️⃣ macOS (zsh — сохранить навсегда)
; ------------------------------------------------------------
; echo 'export NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxx' >> ~/.zshrc


; 4️⃣ Linux (bash — сохранить навсегда)
; ------------------------------------------------------------
; echo 'export NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxx' >> ~/.bashrc


; ============================================================
; ℹ️ Токен должен иметь доступ:
; read:packages
; ℹ️ После установке токена перезагрузите терминал и/или IDE, чтобы изменения вступили в силу.
; ============================================================